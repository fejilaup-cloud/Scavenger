{
  "name": "scavngr-indexer",
  "version": "1.0.0",
  "description": "Stellar contract event indexer for Scavngr",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "migrate": "node dist/db/migrate.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "13.1.0",
    "pg": "8.13.3",
    "dotenv": "16.4.7"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "22.15.3",
    "@types/pg": "8.11.11",
    "jest": "29.7.0",
    "ts-jest": "29.3.2",
    "typescript": "5.8.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "collectCoverageFrom": ["src/**/*.ts"]
  }
}
